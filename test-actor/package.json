{
    "name": "test-actor",
    "version": "0.0.1",
    "type": "module",
    "description": "This is an example of an Apify Actor.",
    "engines": {
        "node": ">=18.0.0"
    },
    "dependencies": {
        "apify": "^3.6.0",
        "apify-client": "^2.22.2",
        "crawlee": "^3.16.0"
    },
    "devDependencies": {
        "@apify/eslint-config": "^1.1.0",
        "@apify/tsconfig": "^0.1.1",
        "@types/node": "^25.3.1",
        "eslint": "^9.39.3",
        "eslint-config-prettier": "^10.1.8",
        "globals": "^17.3.0",
        "prettier": "^3.8.1",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.56.1"
    },
    "scripts": {
        "start": "npm run start:dev",
        "start:prod": "node dist/main.js",
        "start:dev": "tsx src/main.ts",
        "build": "tsc",
        "lint": "eslint",
        "lint:fix": "eslint --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "test": "echo \"Error: oops, the Actor has no tests yet, sad!\" && exit 1",
        "cp": "rm -rf src/orchestrator && mkdir src/orchestrator && cp -r ../src/* src/orchestrator/",
        "push": "npm run cp && ./deploy.js"
    },
    "author": "It's not you it's me",
    "license": "ISC"
}
